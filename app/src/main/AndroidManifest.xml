<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".AppClonerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCloner">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="top.niunaijun.blackbox.provider.BProvider"
            android:authorities="${applicationId}.blackbox.bprovider"
            android:exported="false"
            android:process=":p0" />

        <service
            android:name="top.niunaijun.blackbox.server.BProcessService"
            android:exported="false"
            android:process=":p0" />

        <activity
            android:name="top.niunaijun.blackbox.stub.BActivityStub$P0"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|screenLayout|fontScale|uiMode|orientation|screenSize|smallestScreenSize|layoutDirection|density"
            android:exported="false"
            android:launchMode="standard"
            android:process=":p0"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

    </application> </manifest>